# Copia este archivo a .env y rellena tus valores reales
# NUNCA subas el archivo .env a GitHub

# Base de datos
DB_HOST=localhost
DB_NAME=erp_financiero
APP_ENV=development
DB_USER=root
DB_PASS=

# Entorno: development | production
APP_ENV=development

# URL base del proyecto (con barra final)
URL_BASE=/PHP/erp-financiero/public/

# Google Vision API (para OCR de tickets)
GOOGLE_CREDENTIALS_PATH=